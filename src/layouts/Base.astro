---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Writing about aerospace manufacturing, quality management systems, cyber security, and operations.',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="Jamie Shiers" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>

    <header>
      <div class="container">
        <nav>
          <a href="/" class="nav-logo mono">jamie shiers<span class="accent">_</span></a>
          <div class="nav-links">
            <a href="/" class="mono nav-link">writing</a>
            <a href="/about" class="mono nav-link">about</a>
            <a href="/rss.xml" class="mono nav-link nav-rss" title="RSS Feed">rss</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div class="footer-inner">
          <span class="mono footer-copy">© {new Date().getFullYear()} Jamie Shiers</span>
          <div class="footer-links">
            <a href="https://linkedin.com/in/jamieshiers" class="mono" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://github.com/jamieshiers" class="mono" target="_blank" rel="noopener">GitHub</a>
            <a href="https://parola.dev" class="mono" target="_blank" rel="noopener">Parola</a>
            <a href="/rss.xml" class="mono">RSS</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--border);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
  }
  .nav-logo {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.3px;
  }
  .nav-logo:hover { color: var(--text-primary); }
  .accent { color: var(--accent); }
  .nav-links {
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .nav-link {
    font-size: 12px;
    color: var(--text-muted);
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--text-primary); }
  .nav-rss { color: var(--text-subtle); }
  .nav-rss:hover { color: var(--accent); }

  footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
  }
  .footer-copy {
    font-size: 11px;
    color: var(--text-subtle);
  }
  .footer-links {
    display: flex;
    gap: 20px;
  }
  .footer-links a {
    font-size: 11px;
    color: var(--text-subtle);
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--text-muted); }

  @media (max-width: 600px) {
    .nav-rss { display: none; }
    .footer-inner { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
